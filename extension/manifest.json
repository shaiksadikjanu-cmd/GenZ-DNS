{
  "manifest_version": 3,
  "name": "Janu DNS Overlay",
  "version": "1.2",
  "description": "Integrated Private Internet Command Center.",
  "permissions": [
    "storage", 
    "declarativeNetRequest",
    "sidePanel",
    "tabs"
  ],
"host_permissions": [
    "*://*.firebase.google.com/*",
    "https://*.firestore.googleapis.com/*",
    "https://api.groq.com/*" 
  ],
  "background": {
    "service_worker": "background.js"
  },
  "declarative_net_request": {
    "rule_resources": [{
      "id": "ruleset_1",
      "enabled": true,
      "path": "rules.json"
    }]
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "action": {
    "default_title": "JanuNet Command Center"
  }
}
