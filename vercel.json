{
  "version": 2,
  "rewrites": [
    {
      "source": "/domains/:user/:domain",
      "destination": "/api/domain?user=:user&domain=:domain&backend=janunet"
    },
    {
      "source": "/d/:uid/:domain",
      "destination": "/api/domain?uid=:uid&domain=:domain&backend=byos"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ]
}
