{
  "version": 2,
  "rewrites": [
    { "source": "/u/:username/:domain", "destination": "/api/domain?backend=janunet&username=:username&domain=:domain" },
    { "source": "/s/:ref/:domain",      "destination": "/api/domain?backend=supabase&ref=:ref&domain=:domain" },
    { "source": "/f/:projectId/:domain","destination": "/api/domain?backend=firebase&projectId=:projectId&domain=:domain" },
    { "source": "/api/(.*)",            "destination": "/api/$1" }
  ]
}
